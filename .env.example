# Database
DB_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# Application
SPRING_APPLICATION_NAME=Ceylon-Harvest-Capital
SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8081
APP_CORS_ALLOWED_ORIGINS=http://localhost:[*],https://*.vercel.app,https://*.netlify.app

# JWT
JWT_SECRET=YOUR_BASE64_ENCODED_JWT_SECRET
JWT_EXPIRATION=3600000

# Default admin
ADMIN_DEFAULT_EMAIL=admin@chc.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_DEFAULT_FULLNAME=System Admin

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Blockchain
BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
BLOCKCHAIN_WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY
BLOCKCHAIN_POLYGONSCAN_URL=https://amoy.polygonscan.com/
BLOCKCHAIN_POLYGONSCAN_TX_BASE=https://amoy.polygonscan.com/tx/
BLOCKCHAIN_WALLET_ADDRESS=YOUR_WALLET_ADDRESS
EXTERNAL_DOA_API_BASE_URL=https://www.apiweb.doa.gov.lk

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=milestone-evidence

# SMTP
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=YOUR_APP_EMAIL@gmail.com
SPRING_MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# Chatbots
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_URL=https://api.gemini.ai/v1/chat/completions
GEMINI_MODEL=gemini-2.5-flash

# Hikari
HIKARI_MAX_POOL_SIZE=10
HIKARI_MINIMUM_IDLE=2
HIKARI_IDLE_TIMEOUT=30000
HIKARI_CONNECTION_TIMEOUT=20000

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_RESEND_COUNT=3
OTP_RESEND_WINDOW_MINUTES=10
